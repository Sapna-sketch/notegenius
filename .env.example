# Flask Server Configuration
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000

# AI Configuration (Optional)
# If provided, NoteGenius will use Google Gemini API for high-quality structured note generation.
# If left blank, NoteGenius will automatically fall back to its built-in local extractive NLP engine.
GEMINI_API_KEY=your_gemini_api_key_here
